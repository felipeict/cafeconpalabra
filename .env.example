# ============================================
# GOOGLE SHEETS CONFIGURATION
# ============================================

# Email de la Service Account de Google Cloud
# Ejemplo: cafe-service-account@proyecto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email@project.iam.gserviceaccount.com

# Private Key de la Service Account (incluye los saltos de línea como \n)
# Ejemplo: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# ID del Google Spreadsheet (lo encuentras en la URL del Sheet)
# URL ejemplo: https://docs.google.com/spreadsheets/d/ABC123XYZ456/edit
# El ID es: ABC123XYZ456
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ============================================
# OPCIONAL: Nombres de las hojas del Google Sheet
# (si usas nombres diferentes a los predeterminados)
# ============================================
# SHEET_PRODUCTOS=Productos
# SHEET_TRANSACCIONES=Transacciones
# SHEET_DONACIONES=Donaciones
# SHEET_CAJEROS=Cajeros

